<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.steel.carbon.mapper.DeptInfoMapper">

    <resultMap id="BaseResultMap" type="com.steel.carbon.entity.DeptInfo">
        <id column="id" property="id"/>
        <result column="dept_name" property="deptName"/>
        <result column="manager_name" property="managerName"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.steel.carbon.entity.DeptInfo" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO dept_info (dept_name, manager_name, status)
        VALUES (#{deptName}, #{managerName}, #{status})
    </insert>

    <update id="update" parameterType="com.steel.carbon.entity.DeptInfo">
        UPDATE dept_info
        <set>
            <if test="deptName != null">dept_name = #{deptName},</if>
            <if test="managerName != null">manager_name = #{managerName},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM dept_info WHERE id = #{id}
    </delete>

    <select id="selectById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT * FROM dept_info WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM dept_info ORDER BY create_time DESC
    </select>

    <select id="selectByStatus" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        SELECT * FROM dept_info WHERE status = #{status} ORDER BY create_time DESC
    </select>

</mapper>
