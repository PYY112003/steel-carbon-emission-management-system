<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.steel.carbon.mapper.MaterialEnergyInfoMapper">

    <resultMap id="BaseResultMap" type="com.steel.carbon.entity.MaterialEnergyInfo">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="type" property="type"/>
        <result column="unit" property="unit"/>
        <result column="emission_factor" property="emissionFactor"/>
        <result column="factor_source" property="factorSource"/>
        <result column="remark" property="remark"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.steel.carbon.entity.MaterialEnergyInfo" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO material_energy_info (name, type, unit, emission_factor, factor_source, remark, status)
        VALUES (#{name}, #{type}, #{unit}, #{emissionFactor}, #{factorSource}, #{remark}, #{status})
    </insert>

    <update id="update" parameterType="com.steel.carbon.entity.MaterialEnergyInfo">
        UPDATE material_energy_info
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="type != null">type = #{type},</if>
            <if test="unit != null">unit = #{unit},</if>
            <if test="emissionFactor != null">emission_factor = #{emissionFactor},</if>
            <if test="factorSource != null">factor_source = #{factorSource},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM material_energy_info WHERE id = #{id}
    </delete>

    <select id="selectById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT * FROM material_energy_info WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM material_energy_info ORDER BY create_time DESC
    </select>

    <select id="selectByType" parameterType="java.lang.String" resultMap="BaseResultMap">
        SELECT * FROM material_energy_info WHERE type = #{type} ORDER BY create_time DESC
    </select>

    <select id="selectByStatus" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        SELECT * FROM material_energy_info WHERE status = #{status} ORDER BY create_time DESC
    </select>

</mapper>
